# Copy this file to .env.local for local development,
# and add SITE_PASSWORD in Vercel's Environment Variables for deployment.

SITE_PASSWORD=changeme123

# --- Browserless (required for PDF generation on Vercel) ---
# Sign up free at https://www.browserless.io (1,000 free sessions/month,
# no credit card needed), then copy your API token here.
# Not needed for local dev — local dev uses your own machine's Chromium.
BROWSERLESS_TOKEN=your-browserless-api-token-here

# --- Google Drive (optional) ---
# If these three are left blank, the app just skips Drive upload and
# behaves exactly as before (local download only).
# See README.md "Google Drive setup" for how to get these values.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# --- Company FTP server (optional) ---
# If FTP_HOST/FTP_USER/FTP_PASSWORD are left blank, the app just skips FTP
# upload and behaves as before (local download only). The FTP server must
# be reachable from the internet (not only on your office LAN) for this to
# work, since Vercel's servers connect to it remotely.
FTP_HOST=ftp.yourcompany.com
FTP_PORT=21
FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password
FTP_REMOTE_DIR=/calibration-certificates
FTP_SECURE=false

